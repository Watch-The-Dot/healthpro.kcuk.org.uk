# Ignore everything
*

# Except our bespoke plugins
!plugins/
!plugins/divi-bbpress/
!plugins/divi-bbpress/**
!plugins/healthpro-publications/
!plugins/healthpro-publications/**
!plugins/healthpro-referencing/
!plugins/healthpro-referencing/**
!plugins/healthpro-resources/
!plugins/healthpro-resources/**
!plugins/rss-feed-importer/
!plugins/rss-feed-importer/**
plugins/rss-feed-importer/vendor/
plugins/rss-feed-importer/node_modules/
plugins/rss-feed-importer/dist/
plugins/rss-feed-importer/wp-settings-framework/
plugins/rss-feed-importer/.psysh.php

# Except our child theme
!themes/
!themes/healthpro/
!themes/healthpro/**

# But ignore vendor folders
plugins/*/vendor/
plugins/*/node_modules/
themes/*/node_modules/

# And this file itself
!.gitignore
!.gitattributes